# Kopieer naar .env in de projectmap (staat in .gitignore) of zet deze variabelen in je IDE-runconfig.
# MAIL_SMTP_USER moet exact hetzelfde zijn als het coördinator-e-mailadres waarmee je inlogt
# (pas DataSeeder aan of gebruik een Gmail-account als coördinator in de database).

MAIL_SMTP_ENABLED=true
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=jouw-coordinator@gmail.com
MAIL_SMTP_PASSWORD=app-wachtwoord-van-google
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_AUTH=true
